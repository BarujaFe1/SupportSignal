# SupportSignal — environment example (no secrets)
# Copy values locally as needed. Never commit real credentials.

# Frontend (optional; public lab uses browser engine and does not need API)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Backend FastAPI
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_HOST=127.0.0.1
API_PORT=8000

# Optional future integrations (leave empty for local MVP / lab)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# OPENAI_API_KEY=
# GMAIL_CLIENT_ID=
# STRIPE_SECRET_KEY=
# MERCADOPAGO_ACCESS_TOKEN=
